              "path": ["recommend"]
            },
            "description": "Pride and Prejudice (Austen). If Zilliz has Sense and Sensibility/Emma/etc., the same-author path fires. Otherwise exercises subject overlap (romance, historical fiction). Good cross-check for classic lit coverage."
          }
        },
        {
          "name": "Obscure work — forces Tier 2 (embedding API + async write-back)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"work_key\": \"/works/OL_NOT_IN_ZILLIZ_TEST\",\n  \"title\": \"A Book Almost Certainly Not In The Catalog\",\n  \"author_name\": \"Test Author\",\n  \"subjects\": [\"Fantasy\", \"Magic\", \"Adventure\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"]
            },
            "description": "Deliberately fake work_key. Forces Tier 2: generates embedding from title/author/subjects, queries Zilliz by vector, async write-back adds this record for future Tier 1 hits. Expect fallback_used: true. If EMBEDDING_API_TOKEN is unset, falls to Tier 3 (subject LIKE filter)."
          }
        },
        {
          "name": "Tier 3 simulation — generic subjects, no embedding",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"work_key\": \"/works/OL_TIER3_TEST\",\n  \"title\": \"Test Book\",\n  \"author_name\": \"Test Author\",\n  \"subjects\": [\"fiction\", \"mystery\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"]
            },
            "description": "Simulates Tier 3 path when embedding API is unavailable. The server will attempt Tier 2 first — if the embedding API is offline or returns null, it falls back to subject LIKE filter on the provided subjects. Useful for debugging Tier 3 subject coverage in Zilliz."
          }
        },
        {
          "name": "Work key only — no metadata (hint expected if not in Zilliz)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"work_key\": \"/works/OL45804W\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"]
            },
            "description": "Minimal body — work_key only, no title/author/subjects. If this work_key is in Zilliz (Tier 1), returns recommendations normally. If not, no query_text can be built → returns {recommendations: [], hint: \"Book not in catalog or no metadata provided...\"}. Tests the no-metadata hint path."
          }
        },
        {
          "name": "Invalid token — expects 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer wrong-token" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"work_key\": \"/works/OL893726W\",\n  \"title\": \"Dune\",\n  \"author_name\": \"Frank Herbert\",\n  \"subjects\": [\"Science fiction\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"]
            },
            "description": "Hard-coded wrong token. Expects 401 {\"detail\": \"Invalid token\"} when SECRET_TOKEN is set. If SECRET_TOKEN is unset, auth is skipped and this will succeed — use to confirm token enforcement is working."
          }
        },
        {
          "name": "Missing work_key — expects 422",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"No Work Key Book\",\n  \"author_name\": \"Test\",\n  \"subjects\": [\"Fiction\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"]
            },
            "description": "Body missing required `work_key` field. Expects 422 Unprocessable Entity from Pydantic validation."
          }
        }
      ]
    },
