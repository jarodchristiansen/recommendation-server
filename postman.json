            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"work_key\": \"/works/OL1168083W\",\n  \"title\": \"Nineteen Eighty-Four\",\n  \"author_name\": \"George Orwell\",\n  \"subjects\": [\"Dystopian fiction\", \"Totalitarianism\", \"Political fiction\", \"Science fiction\"]\n}"
