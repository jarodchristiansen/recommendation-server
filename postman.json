{
  "info": {
    "name": "Recommendation Server",
    "description": "FastAPI recommendation-server. Three active route groups:\n\n1. POST /recommend — book recommendations via Zilliz vector search (Tier 1 → Tier 2 → Tier 3 fallback).\n2. POST /recommend/mood — vibe-based book recommendations via Zilliz subject filter.\n3. GET /recommendations/cosine-similarity/:track_id — legacy track recommendations (MongoDB).\n\nAuth: set {{token}} to match SECRET_TOKEN env var. If SECRET_TOKEN is unset, auth is skipped.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "description": "Base URL for the FastAPI server"
    },
    {
      "key": "token",
      "value": "your-secret-token",
      "description": "Must match SECRET_TOKEN env var. Leave blank if SECRET_TOKEN is unset."
    },
    {
      "key": "track_id",
      "value": "example-track-id",
      "description": "MongoDB track_id for legacy cosine-similarity route"
    }
  ],
  "item": [
    {
      "name": "Health & Root",
      "item": [
        {
          "name": "GET / — health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Root health check. Returns {\"message\": \"Hello World\"}. No auth required. HEAD also supported."
          }
        }
      ]
    },
    {
      "name": "Book Recommendations — POST /recommend",
      "description": "Primary book recommendation endpoint. Three-tier fallback:\n• Tier 1: book exists in Zilliz by work_key → returns stored embedding neighbours\n• Tier 2: book not in Zilliz → generates embedding from title/author/subjects, async write-back\n• Tier 3: embedding API unavailable → subject LIKE filter\n\nResponse shape: { recommendations: BookRecord[], fallback_used: bool, hint?: string, embedding_unavailable?: bool }\nEach BookRecord includes an `explanation` string generated by explanation_service.py.",
      "item": [
        {
          "name": "Dune — sci-fi Tier 1 candidate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"work_key\": \"/works/OL893726W\",\n  \"title\": \"Dune\",\n  \"author_name\": \"Frank Herbert\",\n  \"subjects\": [\"Science fiction\", \"Space opera\", \"Epic\", \"Desert planets\", \"Political intrigue\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"]
            },
            "description": "Dune (Frank Herbert). Popular sci-fi — likely in Zilliz (Tier 1). Expect fallback_used: false and semantic explanations (embedding strength + rec subject tags). Subjects are compound OL strings; watch for Jaccard overlap in explanations."
          }
        },
        {
          "name": "The Hobbit — fantasy Tier 1 candidate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"work_key\": \"/works/OL262669W\",\n  \"title\": \"The Hobbit\",\n  \"author_name\": \"J.R.R. Tolkien\",\n  \"subjects\": [\"Fantasy fiction\", \"Magic\", \"Wizards\", \"Middle Earth\", \"Adventure fiction\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"]
            },
            "description": "The Hobbit. Broad fantasy subjects — good for observing subject-overlap explanations (\"Shares thematic overlap in...\"). Tolkien author match will only trigger if a rec is also by Tolkien."
          }
        },
        {
          "name": "Atomic Habits — self-help Tier 1 candidate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
