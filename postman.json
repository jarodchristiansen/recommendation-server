            "body": {
              "mode": "raw",
              "raw": "{\n  \"work_key\": \"/works/OL17930368W\",\n  \"title\": \"Atomic Habits\",\n  \"author_name\": \"James Clear\",\n  \"subjects\": [\"Self-help\", \"Productivity\", \"Habits\", \"Behavior change\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"]
            },
            "description": "Atomic Habits (James Clear). Strong self-help subject signal. Expect Tier 1 if in Zilliz. Good for testing subject-overlap explanations against Zilliz records that have single-word subjects like 'self-help'."
          }
        },
        {
          "name": "The Power of Habit — Tier 1/2 (similar to Atomic Habits)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
