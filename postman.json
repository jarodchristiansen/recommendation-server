              "raw": "{\n  \"work_key\": \"/works/OL1255683W\",\n  \"title\": \"Pride and Prejudice\",\n  \"author_name\": \"Jane Austen\",\n  \"subjects\": [\"Romance fiction\", \"Historical fiction\", \"English literature\", \"Social classes\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommend",
