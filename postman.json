    {
      "name": "Legacy — Track Recommendations (MongoDB)",
      "description": "Legacy cosine-similarity track recommendation route. Auth via query param `token` (not Bearer header). Requires the track to exist in MongoDB with full audio features. Spotify fallback has been removed.",
      "item": [
        {
          "name": "GET cosine-similarity — valid track_id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/recommendations/cosine-similarity/{{track_id}}?token={{token}}&top_n=10",
              "host": ["{{baseUrl}}"],
              "path": ["recommendations", "cosine-similarity", "{{track_id}}"],
              "query": [
                { "key": "token", "value": "{{token}}" },
                { "key": "top_n", "value": "10" }
              ]
            },
            "description": "Returns top_n similar tracks from MongoDB by cosine similarity on audio features (popularity, danceability, energy, valence, loudness, key, speechiness). Auth via query param. Set {{track_id}} to a valid MongoDB track_id."
          }
        },
        {
          "name": "GET cosine-similarity — top_n=5",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/recommendations/cosine-similarity/{{track_id}}?token={{token}}&top_n=5",
              "host": ["{{baseUrl}}"],
              "path": ["recommendations", "cosine-similarity", "{{track_id}}"],
              "query": [
                { "key": "token", "value": "{{token}}" },
                { "key": "top_n", "value": "5" }
              ]
            },
